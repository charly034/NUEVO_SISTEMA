# ─────────────────────────────────────────────
#  La Quinta — Variables de entorno para Docker
#  Copiar a .env y completar antes del primer deploy
# ─────────────────────────────────────────────

# ── Base de datos ──────────────────────────────
POSTGRES_DB=menudb
POSTGRES_USER=la_quinta
POSTGRES_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA

# ── JWT ────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_LARGO
JWT_EXPIRES_IN=7d

# ── CORS — dominios del frontend (sin barra final) ──
# Ejemplo: https://pedidos.laquinta.com.ar,https://admin.laquinta.com.ar
CORS_ORIGINS=https://TU_DOMINIO_CLIENTES,https://TU_DOMINIO_ADMIN

# ── Zona horaria ───────────────────────────────
APP_TIMEZONE=America/Argentina/Buenos_Aires

# ── Seeds — primer deploy (ejecutar UNA sola vez) ───
# DEMO_ADMIN_EMAIL=admin@laquinta.com.ar
# DEMO_ADMIN_PASSWORD=CambiarEsto123!

# ─────────────────────────────────────────────
#  PASOS PARA EL PRIMER DEPLOY
# ─────────────────────────────────────────────
#  1. Copiar este archivo a .env y completar todos los valores
#  2. docker compose up -d --build
#  3. Crear admin inicial:
#       docker compose exec api node scripts/seed-admin.js
#  4. (Opcional) Importar platos y menús:
#       docker compose exec api npm run seed:fijos
#       docker compose exec api npm run seed
# ─────────────────────────────────────────────
