NODE_ENV=development
PORT=3000

# Variables individuales (útiles para más control local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password
DB_SSL=false

# DATABASE_URL (útil para deploys en Railway, Render, Heroku, etc.)
# En producción generalmente el proveedor te da esta variable lista.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db

# Seguridad
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d
APP_TIMEZONE=America/Argentina/Buenos_Aires
TRUST_PROXY_HOPS=1

# Orígenes permitidos, separados por coma. Obligatorio en producción.
CORS_ORIGINS=http://localhost:5174,http://localhost:5175

# Solo para seed:demo
DEMO_ADMIN_EMAIL=admin@laquinta.local
DEMO_ADMIN_PASSWORD=cambiar-por-una-clave-de-al-menos-12-caracteres
DEMO_CLIENT_PASSWORD=cambiar-por-una-clave-de-al-menos-12-caracteres
