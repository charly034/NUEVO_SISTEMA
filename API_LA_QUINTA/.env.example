NODE_ENV=development
PORT=3000

# Variables individuales (útiles para más control local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# DATABASE_URL (útil para deploys en Railway, Render, Heroku, etc.)
# En producción generalmente el proveedor te da esta variable lista.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db

# Seguridad
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d
APP_TIMEZONE=America/Argentina/Buenos_Aires
TRUST_PROXY_HOPS=1

# Orígenes permitidos, separados por coma. Obligatorio en producción.
CORS_ORIGINS=http://localhost:5174,http://localhost:5175

# Solo para seed:demo
DEMO_ADMIN_EMAIL=admin-operativo@laquinta.local
DEMO_ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_DEMO_LARGO
DEMO_CLIENT_PASSWORD=CAMBIAR_POR_PASSWORD_DEMO_LARGO
TEST_DATA_PASSWORD=12345678
SEED_FULL_RESET_CONFIRM=RESET_DEV_DATABASE
SUPERADMIN_EMAIL=superadmin@laquinta.local
SUPERADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SUPERADMIN_LARGO
DEFAULT_DEMO_PASSWORD=CAMBIAR_POR_PASSWORD_DEMO_LARGO
CLEAN_TEST_DATA_CONFIRM=ELIMINAR_DATOS_PRUEBA
# Solo desarrollo: reset manual de contraseña de administrador
ADMIN_EMAIL=superadmin@laquinta.local
ADMIN_NEW_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN_LARGO
