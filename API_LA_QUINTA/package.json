{
  "name": "api-la-quinta",
  "version": "1.0.0",
  "description": "API REST base profesional - La Quinta",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node-pg-migrate up --migrationsDir=\"src/database/migrations\"",
    "migrate:rollback": "node-pg-migrate down --migrationsDir=\"src/database/migrations\"",
    "migrate:create": "node-pg-migrate create --migrationsDir=\"src/database/migrations\"",
    "seed": "node scripts/import-menus-csv.js",
    "seed:fijos": "node scripts/seed-platos-fijos.js",
    "seed:demo": "node scripts/seed-empresa-demo.js",
    "seed:admin": "node scripts/seed-admin.js",
    "setup": "npm run migrate && npm run seed && npm run seed:fijos",
    "test": "node --test",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^7.4.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "nodemon": "^3.1.4"
  },
  "overrides": {
    "glob": "^11.1.0"
  }
}
